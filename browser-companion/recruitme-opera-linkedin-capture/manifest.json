{
  "manifest_version": 3,
  "name": "RecruitMe LinkedIn Capture",
  "description": "Capture full LinkedIn profiles into RecruitMe. Works in Chrome, Opera, Edge, and Firefox.",
  "version": "1.2.9",
  "permissions": ["storage", "tabs", "activeTab", "alarms", "notifications"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.up.railway.app/*",
    "https://recruitme.railway.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://10.255.255.254/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "RecruitMe LinkedIn Capture",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "recruitme-linkedin-capture@recruitme",
      "strict_min_version": "109.0"
    }
  }
}
