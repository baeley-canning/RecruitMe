# Database — PostgreSQL (Railway provides this automatically via ${{Postgres.DATABASE_URL}})
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-app.railway.app"

# AI Provider: "claude" | "openai" | "ollama"
AI_PROVIDER=claude

# Claude (Anthropic) — primary AI provider
# Models: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (best quality)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI — alternative provider (switch AI_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama — local fallback (switch AI_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# SerpAPI — enables automatic LinkedIn profile search (100 searches/month free)
# Sign up at https://serpapi.com
SERPAPI_API_KEY=

# People Data Labs — profile enrichment + candidate search (100 free calls/month)
# Sign up at https://peopledatalabs.com
PDL_API_KEY=

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.railway.app
