NEXT_PUBLIC_APP_URL=http://localhost:3000

SEARCHDESK_SESSION_SECRET=change-me-for-shared-office-use
SEARCHDESK_WORKSPACE_ACCESS_CODE=
SEARCHDESK_ALLOW_SELF_ASSIGN_OWNER=0

SEARCHDESK_AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# If you want the OpenAI API instead, switch provider to `openai`
# and add a real API key and model.
OPENAI_API_KEY=
SEARCHDESK_OPENAI_MODEL=gpt-5.4-mini

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/integrations/linkedin/callback
SEARCHDESK_LINKEDIN_REMEMBER_DAYS=30

# External LinkedIn-derived search provider for one-click JD matching.
# SearchDesk will check the internal candidate library first, then hit this provider.
SEARCHDESK_LINKEDIN_SEARCH_PROVIDER=serpapi
SERPAPI_API_KEY=469fab18bdc409bdd3149955e41a37aad121225ff69c5f1c29ad19d185794d61
SERPAPI_BASE_URL=https://serpapi.com/search.json
