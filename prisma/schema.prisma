generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "darwin", "darwin-arm64", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String?
  location    String?
  rawJd       String
  parsedRole  String?  // JSON string: parsed AI output
  salaryMin   Int?     // NZD yearly minimum (optional)
  salaryMax   Int?     // NZD yearly maximum (optional)
  isRemote    Boolean  @default(false)
  status      String   @default("active") // active | closed | on-hold
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates     Candidate[]
  fetchSessions  FetchSession[]
  searchSessions SearchSession[]
  orgId          String?
  org            Org?     @relation(fields: [orgId], references: [id])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Org {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  jobs      Job[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // bcrypt hash
  role      String   @default("user") // "owner" | "user"
  orgId     String?
  org       Org?     @relation(fields: [orgId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Candidate {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  name         String
  headline     String?
  location     String?
  linkedinUrl  String?
  profileText  String?  // Raw pasted/captured profile text
  matchScore       Int?
  matchReason      String?  // AI JSON: { summary, strengths, gaps }
  acceptanceScore  Int?
  acceptanceReason String?  // AI JSON: { likelihood, headline, signals, summary }
  scoreBreakdown   String?  // Structured scoring JSON: ScoreBreakdown type
  notes            String?  // Recruiter notes
  screeningData    String?  // JSON: {availability,salaryExpectation,visaStatus,noticePeriod,motivations,notes,screenedAt}
  interviewNotes   String?  // JSON: {date,interviewer,format,impression,technical,culture,recommendation,updatedAt}
  status       String   @default("new") // new | reviewing | shortlisted | contacted | interviewing | offer_sent | hired | declined | rejected
  statusHistory    String?  // JSON: [{status, changedAt}]
  contactedAt      DateTime?
  source       String   @default("manual") // manual | serpapi | pdl | extension | talent_pool
  profileCapturedAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  references    ReferenceCheck[]
  files         CandidateFile[]
  fetchSessions FetchSession[]

  @@unique([jobId, linkedinUrl])
}

model CandidateFile {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  type        String    // "cv" | "cover_letter" | "other"
  filename    String
  mimeType    String
  data        String    // base64 encoded file content
  size        Int       // original size in bytes
  createdAt   DateTime  @default(now())
}

// Replaces the Setting-JSON extension queue — proper indexed table per session.
model FetchSession {
  id            String    @id @default(cuid())
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  linkedinUrl   String
  candidateName String    @default("")
  status        String    @default("pending") // pending | processing | completed | error
  message       String    @default("")
  error         String?
  completedAt   DateTime?
  orgId         String?
  userId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([candidateId])
  @@index([jobId])
  @@index([status])
}

// Persists search progress so partial results survive rate-limit interruptions.
model SearchSession {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status      String   @default("running") // running | complete | rate_limited
  queries     String   // JSON: string[]
  location    String
  collected   Int      @default(0)
  target      Int
  page        Int      @default(0)
  importedIds String   @default("[]") // JSON: candidateId[]
  message     String?
  orgId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobId])
}

model ReferenceCheck {
  id              String    @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  refereeName     String
  refereeTitle    String?
  refereeCompany  String?
  refereeEmail    String?
  refereePhone    String?
  relationship    String?   // "Direct manager" | "Peer" | "Report" | "Client"

  status          String    @default("pending") // pending | contacted | received | complete
  questions       String?   // JSON: [{question, category}]
  responses       String?   // JSON: [{question, answer}]
  summary         String?   // AI-generated paragraph

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
